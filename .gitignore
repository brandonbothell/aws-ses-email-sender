.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Whether you use PnP or not, the node_modules folder is often used to store
# build artifacts that should be gitignored
node_modules

# Swap the comments on the following lines if you wish to use zero-installs
# In that case, don't forget to run `yarn config set enableGlobalCache false`!
# Documentation here: https://yarnpkg.com/features/caching#zero-installs

#!.yarn/cache
.pnp.*

# Local env files, which may contain sensitive information like API keys or database credentials
.env

# Attachments folder, which may contain large/sensitive files that should not be committed to the repository
attachments/**/*
!attachments/**/*.gitkeep
!attachments/**/email.example.html
!attachments/**/doggos.jpg
